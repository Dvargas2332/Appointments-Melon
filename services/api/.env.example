DATABASE_URL="postgresql://melon:password@localhost:5432/melon?schema=public"
DIRECT_URL="postgresql://melon:password@localhost:5432/melon?schema=public"
PORT=3000
TZ=Asia/Tokyo
JWT_SECRET="cambia-esta-clave"
JWT_EXPIRES_IN="10d"
OAUTH_ISSUER="https://oauth.kazehanacloud.com"
OAUTH_CLIENT_ID="melon-mobile"
OAUTH_AUDIENCE="melon-api"
# Opcional si tu proveedor publica el JWKS en otra ruta.
OAUTH_JWKS_URI="https://oauth.kazehanacloud.com/.well-known/jwks.json"

# Google
OAUTH_GOOGLE_ISSUER="https://accounts.google.com"
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_AUDIENCE=""
OAUTH_GOOGLE_ALLOWED_AUDIENCES=""
OAUTH_GOOGLE_JWKS_URI=""

# Apple
OAUTH_APPLE_ISSUER="https://appleid.apple.com"
OAUTH_APPLE_CLIENT_ID=""
OAUTH_APPLE_AUDIENCE=""
OAUTH_APPLE_ALLOWED_AUDIENCES=""
OAUTH_APPLE_JWKS_URI="https://appleid.apple.com/auth/keys"

# LINE
OAUTH_LINE_ISSUER="https://access.line.me"
OAUTH_LINE_CLIENT_ID=""
OAUTH_LINE_AUDIENCE=""
OAUTH_LINE_ALLOWED_AUDIENCES=""
OAUTH_LINE_JWKS_URI="https://api.line.me/oauth2/v2.1/certs"

# X
OAUTH_X_ISSUER=""
OAUTH_X_CLIENT_ID=""
OAUTH_X_AUDIENCE=""
OAUTH_X_ALLOWED_AUDIENCES=""
OAUTH_X_JWKS_URI=""
