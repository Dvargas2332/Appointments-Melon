# -----------------------------------------------------------------------------
# Melon API - example environment file
# Copy this file to `services/api/.env` and replace the placeholder values.
# Do not commit your real secrets.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection used by Prisma at runtime.
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/melon_db?schema=public"

# Direct connection for Prisma migrations / admin operations.
# In many local setups this can be the same as DATABASE_URL.
DIRECT_URL="postgresql://db_user:db_password@localhost:5432/melon_db?schema=public"

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Port where the NestJS API will listen.
PORT=3000

# Default timezone used by the server for date/time handling.
# Example values: UTC, America/Costa_Rica, Asia/Tokyo
TZ="UTC"

# -----------------------------------------------------------------------------
# Internal JWT issued by your backend
# -----------------------------------------------------------------------------
# Secret used to sign Melon session tokens.
# Use a long random string in real environments.
JWT_SECRET="replace-with-a-long-random-secret"

# Expiration for the internal JWT.
# Examples: 1d, 7d, 10d, 12h
JWT_EXPIRES_IN="10d"

# -----------------------------------------------------------------------------
# Default OAuth / OIDC provider
# -----------------------------------------------------------------------------
# Use this section if you want one default identity provider for the app.
# If you only use provider-specific sections below, these can remain empty.
OAUTH_ISSUER=""
OAUTH_CLIENT_ID=""

# Audience expected by your backend when validating tokens.
# Leave empty only if your provider truly does not use audience validation.
OAUTH_AUDIENCE=""

# Optional comma-separated list of extra accepted audiences.
# Example: "melon-api,melon-mobile"
OAUTH_ALLOWED_AUDIENCES=""

# Optional JWKS endpoint override.
# Leave empty if the provider exposes discovery metadata correctly.
OAUTH_JWKS_URI=""

# -----------------------------------------------------------------------------
# Google OAuth / OIDC
# -----------------------------------------------------------------------------
# Official issuer is usually:
#   https://accounts.google.com
OAUTH_GOOGLE_ISSUER="https://accounts.google.com"
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_AUDIENCE=""

# Optional comma-separated list of accepted audiences.
OAUTH_GOOGLE_ALLOWED_AUDIENCES=""

# Leave empty unless you need to override JWKS discovery.
OAUTH_GOOGLE_JWKS_URI=""

# -----------------------------------------------------------------------------
# Apple Sign In
# -----------------------------------------------------------------------------
OAUTH_APPLE_ISSUER="https://appleid.apple.com"
OAUTH_APPLE_CLIENT_ID=""
OAUTH_APPLE_AUDIENCE=""
OAUTH_APPLE_ALLOWED_AUDIENCES=""

# Apple public keys endpoint.
OAUTH_APPLE_JWKS_URI="https://appleid.apple.com/auth/keys"

# -----------------------------------------------------------------------------
# LINE Login / OIDC
# -----------------------------------------------------------------------------
OAUTH_LINE_ISSUER="https://access.line.me"
OAUTH_LINE_CLIENT_ID=""
OAUTH_LINE_AUDIENCE=""
OAUTH_LINE_ALLOWED_AUDIENCES=""

# LINE certs endpoint.
OAUTH_LINE_JWKS_URI="https://api.line.me/oauth2/v2.1/certs"

# -----------------------------------------------------------------------------
# X OAuth
# -----------------------------------------------------------------------------
# Fill these only if you support X login in your backend.
OAUTH_X_ISSUER=""
OAUTH_X_CLIENT_ID=""
OAUTH_X_AUDIENCE=""
OAUTH_X_ALLOWED_AUDIENCES=""
OAUTH_X_JWKS_URI=""

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# 1. You do not need to fill every provider. Only configure the ones you use.
# 2. The frontend app must use matching CLIENT_ID / issuer values.
# 3. After editing this file, restart the API.
